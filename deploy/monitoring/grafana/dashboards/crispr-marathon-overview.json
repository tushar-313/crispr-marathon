{
  "uid": "crispr-overview",
  "title": "CRISPR Marathon - Overview",
  "tags": ["crispr", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "App Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "refId": "A", "expr": "max(crispr_app_up)" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "gridPos": { "x": 6, "y": 0, "w": 9, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "crispr_system_cpu_usage_percent" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (%)",
      "gridPos": { "x": 15, "y": 0, "w": 9, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "crispr_system_memory_usage_percent" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Disk Usage (%)",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "crispr_system_disk_usage_percent" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Load Average",
      "gridPos": { "x": 6, "y": 8, "w": 18, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "crispr_system_load_average" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests / sec",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "refId": "A", "expr": "sum(rate(crispr_http_requests_total[5m]))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency (s)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(crispr_http_request_duration_seconds_bucket[5m])) by (le))"
        }
      ]
    }
  ]
}
